{
  "version": "0.2",
  "language": "en-GB",
  "flagWords": ["teh", "hte"],
  "ignorePaths": ["node_modules", "dist", ".git", "*.min.js", "*.min.css", "projects/**", "public/files/**"],
  "dictionaries": [
    "en-gb",
    "softwareTerms",
    "references_dictionary",
    "unicamp_dictionary",
    "words_dictionary",
    "programming_dictionary"
  ],
  "dictionaryDefinitions": [
    {
      "name": "references_dictionary",
