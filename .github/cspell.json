    },
    {
      "name": "words_dictionary",
      "path": "./.cspell/words_dictionary.txt",
      "addWords": true
    },
    {
      "name": "unicamp_dictionary",
      "path": "./.cspell/unicamp_dictionary.txt",
      "addWords": true
    },
    {
      "name": "programming_dictionary",
      "path": "./.cspell/programming_dictionary.txt",
      "addWords": true
    }
  ]
