---
import Base from "./Base.astro";

interface Props {
  frontmatter?: {
    title: string;
    subtitle?: string;
  };
  title?: string;
  subtitle?: string;
}

const { frontmatter, title: propsTitle, subtitle: propsSubtitle } = Astro.props;
const title = frontmatter?.title ?? propsTitle ?? "";
const subtitle = frontmatter?.subtitle ?? propsSubtitle;
---

<Base title={title}>
  <article>
    <header>
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
    </header>
    <slot />
  </article>
</Base>
