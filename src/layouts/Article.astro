---
import Base from "./Base.astro";

interface Props {
  frontmatter?: { title?: string; subtitle?: string };
  title?: string;
  subtitle?: string;
}

const props = Astro.props;
const title = props.frontmatter?.title ?? props.title ?? "";
const subtitle = props.frontmatter?.subtitle ?? props.subtitle;
---

<Base title={title}>
  <article>
    <header>
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
    </header>
    <slot />
  </article>
</Base>
