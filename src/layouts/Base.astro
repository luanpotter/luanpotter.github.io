---
interface Props {
  frontmatter?: { title?: string };
  title?: string;
}

const props = Astro.props;
const title = props.frontmatter?.title ?? props.title ?? "Luan";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
