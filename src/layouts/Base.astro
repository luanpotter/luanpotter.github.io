---
import "drop-in-css";

interface Props {
  frontmatter?: { title?: string };
  title?: string;
}

const props = Astro.props;
const title = props.frontmatter?.title ?? props.title ?? "Luan";
const pathname = Astro.url.pathname;

const menuItems = [
  { href: "/", label: "luan" },
  { href: "/projects", label: "projects" },
  { href: "/articles", label: "articles" },
  { href: "/stuff", label: "stuff" },
  { href: "https://github.com/luanpotter", label: "github" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

const menuHtml = menuItems
  .map(({ href, label }) => `<a href="${href}"${isActive(href) ? ' class="active"' : ""}><span>${label}</span></a>`)
  .join("");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div id="root">
      <menu set:html={menuHtml} />
      <main>
        <section>
          <slot />
        </section>
      </main>
    </div>
  </body>
</html>
