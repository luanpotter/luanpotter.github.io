---
import "drop-in-css";

interface Props {
  frontmatter?: { title?: string };
  title?: string;
}

const props = Astro.props;
const title = props.frontmatter?.title ?? props.title ?? "Luan";
const pathname = Astro.url.pathname;

const menuItems = [
  { href: "/", label: "luan" },
  { href: "/projects", label: "projects", alternativePaths: ["/unicamp"] },
  { href: "/articles", label: "articles", alternativePaths: ["/blog"] },
  { href: "/stuff", label: "stuff" },
  { href: "https://github.com/luanpotter", label: "github" },
];

function isActive(href: string, alternativePaths: string[]): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href) || alternativePaths.some((path) => pathname.startsWith(path));
}

const menuHtml = menuItems
  .map(
    ({ href, label, alternativePaths }) =>
      `<a href="${href}"${isActive(href, alternativePaths ?? []) ? ' class="active"' : ""}><span>${label}</span></a>`,
  )
  .join("");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div id="root">
      <menu set:html={menuHtml} />
      <main>
        <section>
          <slot />
        </section>
      </main>
      <footer>
        Luan Nico •
        <a href="https://github.com/luanpotter">@luanpotter</a> •
        <a href="https://luan.xyz">luan.xyz</a> •
        <a href="https://luan.xyz/rss.xml">rss</a> /
        <a href="https://luan.xyz/atom.xml">atom</a> •
        <a id="toggle-css" href="#">nuke css</a>
      </footer>
    </div>
    <script src="../utils/css-toggle.ts"></script>
  </body>
</html>
