---
interface Props {
  image: {
    src: string;
  };
  legend?: string;
  maxWidth?: string;
}

const { image, legend, maxWidth } = Astro.props;
---

<figure style={{ display: "flex", alignItems: "center", flexDirection: "column" }}>
  <img src={image.src} alt={legend} style={{ maxWidth: maxWidth || "80%", height: "auto" }} />
  {legend && <figcaption>{legend}</figcaption>}
</figure>
